# =========================================================================
# MadHats AI Design Studio — environment variables
# Copy to .env and fill in. NEVER commit a real .env.
# =========================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=madhats-assets

# --- Claude (conversation LLM) ---
ANTHROPIC_API_KEY=
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# --- Image generation (model IDs ONLY in env — never hardcoded) ---
GEMINI_API_KEY=
IMAGE_PROVIDER_PREVIEW=stub            # stub | gemini_flash | gemini_pro
IMAGE_PROVIDER_FINAL=stub              # stub | gemini_flash | gemini_pro
# Must be image-OUTPUT models (verify availability for your key via ListModels):
GEMINI_PREVIEW_MODEL=gemini-2.5-flash-image
GEMINI_FINAL_MODEL=gemini-3-pro-image

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=studio@madhats.com.au
SALES_NOTIFICATION_EMAIL=sales@madhats.com.au

# --- Security ---
ADMIN_SECRET=change-me-in-production
RATE_LIMIT_RPM=10
SIGNED_URL_TTL=3600
ALLOWED_ORIGINS=https://madhats.com.au,http://localhost:5173
VERIFICATION_TOKEN_TTL_SECONDS=900

# --- App ---
APP_ENV=development
SENTRY_DSN=
EMAIL_VERIFY_BASE_URL=http://localhost:8000
CHATBOT_PERSONA_NAME=Ricardo
