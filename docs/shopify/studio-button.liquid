{%- comment -%}
  MadHats AI Design Studio — "Design This Hat" button
  ---------------------------------------------------------------------------
  Drop this snippet into a product template/section (or paste it into a
  theme "Custom Liquid" block on the product page) to add a button that opens
  the AI Design Studio for the product the customer is currently viewing.

  It links to:
    {{ STUDIO_URL }}/?product_id={{ product.id }}&variant_id=...&colour=...&source=shopify

  - product_id  = {{ product.id }}  (the stable Shopify product id — the Studio
                  backend resolves this via product_references.shopify_product_id)
  - variant_id  = the currently selected variant (kept in sync on variant change)
  - colour      = the value of the product's colour option, if it has one
  - source      = "shopify" (attribution; surfaces in the session's entryContext)

  SETUP: set STUDIO_URL below to your Studio host. Prod example:
    http://madhats.getaiconsult.com.au:5173
  No trailing slash.
{%- endcomment -%}

{%- assign STUDIO_URL = 'http://madhats.getaiconsult.com.au:5173' -%}

{%- comment -%} Find which option (if any) is the colour option. {%- endcomment -%}
{%- assign colour_position = 0 -%}
{%- for opt in product.options_with_values -%}
  {%- assign name_down = opt.name | downcase -%}
  {%- if name_down contains 'colour' or name_down contains 'color' -%}
    {%- assign colour_position = opt.position -%}
  {%- endif -%}
{%- endfor -%}

{%- assign current = product.selected_or_first_available_variant -%}
{%- if colour_position == 1 -%}
  {%- assign current_colour = current.option1 -%}
{%- elsif colour_position == 2 -%}
  {%- assign current_colour = current.option2 -%}
{%- elsif colour_position == 3 -%}
  {%- assign current_colour = current.option3 -%}
{%- endif -%}

<div class="madhats-studio-cta">
  <a
    class="madhats-studio-button"
    href="{{ STUDIO_URL }}/?product_id={{ product.id }}&variant_id={{ current.id }}{% if current_colour %}&colour={{ current_colour | url_encode }}{% endif %}&source=shopify"
    target="_blank"
    rel="noopener"
    data-madhats-studio
    data-studio-url="{{ STUDIO_URL }}"
    data-product-id="{{ product.id }}"
    data-colour-position="{{ colour_position }}"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
         style="flex:0 0 auto">
      <path d="M12 3l2.09 4.24L18.9 8l-3.45 3.36.81 4.74L12 13.77 7.74 16.1l.81-4.74L5.1 8l4.81-.76L12 3z"
            fill="currentColor"/>
    </svg>
    <span>Design This Hat with AI</span>
  </a>
</div>

<style>
  .madhats-studio-cta { margin: 12px 0; }
  .madhats-studio-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 8px;
    background: #111827;
    color: #ffffff;
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background .15s ease, transform .05s ease;
  }
  .madhats-studio-button:hover { background: #1f2937; }
  .madhats-studio-button:active { transform: translateY(1px); }
  .madhats-studio-button:focus-visible { outline: 2px solid #6366f1; outline-offset: 2px; }
</style>

<script>
  // Keep variant_id + colour in the Studio link current as the customer changes
  // the variant selector. Theme-agnostic: reads the product form's [name="id"]
  // and the shop's variant JSON. Fails silent if the theme is unusual — the
  // initial (server-rendered) link already points at the first available variant.
  (function () {
    // Query by attribute (the <script> may be relocated by the theme).
    var link = document.querySelector('a[data-madhats-studio]');
    if (!link) return;

    var studioUrl = link.getAttribute('data-studio-url');
    var productId = link.getAttribute('data-product-id');
    var colourPos = parseInt(link.getAttribute('data-colour-position') || '0', 10);

    function buildHref(variantId, colour) {
      var url = studioUrl + '/?product_id=' + encodeURIComponent(productId);
      if (variantId) url += '&variant_id=' + encodeURIComponent(variantId);
      if (colour) url += '&colour=' + encodeURIComponent(colour);
      url += '&source=shopify';
      return url;
    }

    // Find the product form's variant id input, if present.
    var form = link.closest('form[action*="/cart/add"]') ||
               document.querySelector('form[action*="/cart/add"]');
    var idInput = form && form.querySelector('[name="id"]');
    if (!idInput) return; // no selector to watch — keep the server-rendered link

    // Look up the variant's colour option from window variant data if available.
    var variants = (window.ShopifyAnalytics
                    && window.ShopifyAnalytics.meta
                    && window.ShopifyAnalytics.meta.product
                    && window.ShopifyAnalytics.meta.product.variants) || null;

    function colourFor(variantId) {
      if (!variants || !colourPos) return null;
      for (var i = 0; i < variants.length; i++) {
        if (String(variants[i].id) === String(variantId)) {
          // meta variant option values live on .options (position-1 indexed)
          var opts = variants[i].options || [];
          return opts[colourPos - 1] || null;
        }
      }
      return null;
    }

    function update() {
      var vid = idInput.value;
      link.setAttribute('href', buildHref(vid, colourFor(vid)));
    }

    idInput.addEventListener('change', update);
    // Some themes update [name="id"] without firing 'change' — poll lightly.
    var last = idInput.value;
    setInterval(function () {
      if (idInput.value !== last) { last = idInput.value; update(); }
    }, 500);
  })();
</script>
